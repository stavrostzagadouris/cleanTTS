# The URL of your vLLM chat model (on the 5090 machine)
LM_STUDIO_BASE_URL=http://100.x.y.z:1234/v1

# The URL of your vLLM-Omni TTS server (on the 5090 machine)
VOXTRAL_TTS_BASE_URL=http://localhost:8000/v1

# Whisper configuration (runs on your local 3080)
WHISPER_MODEL=distil-large-v3
WHISPER_DEVICE=cuda
