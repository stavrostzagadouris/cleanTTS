# Copy this to `.env` and fill in your own values. `.env` is gitignored.

# JSON list of LLM backends. Each entry needs a name (shown in the UI dropdown)
# and a URL pointing at any OpenAI-compatible /v1 endpoint (vLLM, LM Studio, Ollama, etc.).
#
# Optional per-backend "chat_template_kwargs" is forwarded into every chat
# completion request. Use this to disable Qwen3 thinking for THIS app only —
# other clients hitting the same backend are unaffected since the kwarg is
# per-request:
#   {"name":"...","url":"...","chat_template_kwargs":{"enable_thinking":false}}
LLM_BACKENDS=[{"name":"server-a","url":"http://100.x.y.z:1234/v1","chat_template_kwargs":{"enable_thinking":false}},{"name":"server-b","url":"http://100.x.y.z:1234/v1"}]

# Single-backend fallback (used only if LLM_BACKENDS is unset or invalid)
# LLM_BASE_URL=http://localhost:1234/v1

# Local Whisper (STT)
WHISPER_MODEL=distil-large-v3                  # or 'small', 'medium', etc.
WHISPER_DEVICE=cuda                            # or 'cpu'

# Kokoro TTS
# Comma-separated lang_codes; one KPipeline is loaded per language. Each
# pipeline is ~300MB VRAM. Pick a voice id that matches one of the loaded
# languages (voice prefix = lang_code, e.g. "bf_emma" needs "b").
#   a=American English  b=British English   j=Japanese   z=Mandarin
#   e=Spanish           f=French            h=Hindi      i=Italian   p=Brazilian Portuguese
KOKORO_LANGS=a,b
DEFAULT_VOICE=af_bella

# Voice assistant system prompt
SYSTEM_PROMPT=You are a helpful, concise voice assistant. Replies are spoken aloud, so keep them short and natural for speech (no markdown, no bullet lists, no headers). Input is transcribed from the user's voice and may contain occasional mis-heard words or odd artifacts — if something looks like a transcription glitch, infer what they likely meant when context makes it obvious, otherwise ask a brief clarifying question rather than answering the literal nonsense.

# Server
HOST=0.0.0.0
PORT=5000
